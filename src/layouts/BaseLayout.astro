---
interface Props {
  title: string;
  description?: string;
  activePage?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const { title, description = '', activePage = '', ogTitle, ogDescription } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  {ogTitle && <meta property="og:title" content={ogTitle} />}
  {ogDescription && <meta property="og:description" content={ogDescription} />}
  {(ogTitle || ogDescription) && <meta property="og:type" content="website" />}
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; object-src 'none'; base-uri 'self';" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta http-equiv="X-Content-Type-Options" content="nosniff" />
  <link rel="icon" type="image/x-icon" href={`${base}/favicon.ico`} />
  <link rel="icon" type="image/png" sizes="32x32" href={`${base}/favicon-32x32.png`} />
  <link rel="icon" type="image/png" sizes="16x16" href={`${base}/favicon-16x16.png`} />
  <link rel="apple-touch-icon" sizes="180x180" href={`${base}/apple-touch-icon.png`} />
  <script is:inline>
    (function(){try{var s=localStorage.getItem('portfolio-theme');var t=(s==='dark'||s==='light')?s:(window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');document.documentElement.classList.add('theme-'+t);}catch(_){}})();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=JetBrains+Mono:wght@300;400;500&family=Geist:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&family=Playfair+Display:wght@600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,300;1,8..60,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href={`${base}/css/style.css`} />
  <script is:inline define:vars={{ portfolioBase: base }}>window.__PORTFOLIO_BASE__ = portfolioBase;</script>
</head>
<body>

<div class="site-wrapper">

  <!-- ── LEFT SIDEBAR ── -->
  <aside class="sidebar-left">
    <div class="sidebar-logo">
      <a href={`${base}/`} class="sidebar-site-name" aria-label="Home">Sayyaku</a>
    </div>
    <nav class="sidebar-nav">
      <a href={`${base}/`} class:list={['nav-item', { active: activePage === 'home' }]} data-page="index.html">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/><polyline points="9 21 9 12 15 12 15 21"/></svg>
        <span class="nav-label">Home</span>
      </a>
      <a href={`${base}/writings.html`} class:list={['nav-item', { active: activePage === 'writings' }]} data-page="writings.html">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        <span class="nav-label">Writings</span>
      </a>
      <a href={`${base}/projects.html`} class:list={['nav-item', { active: activePage === 'projects' }]} data-page="projects.html">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        <span class="nav-label">Projects</span>
      </a>
      <a href={`${base}/about.html`} class:list={['nav-item', { active: activePage === 'about' }]} data-page="about.html">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        <span class="nav-label">About</span>
      </a>
      <a href={`${base}/notes.html`} class:list={['nav-item', { active: activePage === 'notes' }]} data-page="notes">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v16H4z"/><path d="M8 9h8M8 13h8M8 17h5"/></svg>
        <span class="nav-label">Notes</span>
      </a>
    </nav>
    <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle theme" aria-pressed="false">
      <span class="theme-toggle-icon" aria-hidden="true">&#9728;</span>
      <span class="theme-toggle-label">Light</span>
    </button>
    <div class="sidebar-profile">
      <div class="avatar">S</div>
      <div class="profile-info">
        <div class="profile-name">Sayyaku</div>
        <div class="profile-handle">@SayyakuHajime</div>
      </div>
    </div>
  </aside>

  <!-- ── MAIN ── -->
  <main class="main-content">
    <slot />
  </main>

  <!-- ── RIGHT RAIL ── -->
  <aside class="sidebar-right">
    <slot name="right-rail" />
  </aside>

</div>

<script is:inline src={`${base}/js/app.js`} defer></script>
</body>
</html>
