---
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  activeNote?: string;
  activeSlug?: string;
  pageTitle?: string;
  pageMeta?: string;
  hideHeader?: boolean;
  useKatex?: boolean;
}

const {
  title,
  activeNote = '',
  activeSlug = '',
  pageTitle = '',
  pageMeta = '',
  hideHeader = false,
  useKatex = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;

const collectionNotes = (await getCollection('notes'))
  .sort((a, b) => a.data.order - b.data.order);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta http-equiv="Content-Security-Policy" content="object-src 'none'; base-uri 'self';" />
  <link rel="icon" type="image/x-icon" href={`${base}/favicon.ico`} />
  <link rel="icon" type="image/png" sizes="32x32" href={`${base}/favicon-32x32.png`} />
  <link rel="icon" type="image/png" sizes="16x16" href={`${base}/favicon-16x16.png`} />
  <link rel="apple-touch-icon" sizes="180x180" href={`${base}/apple-touch-icon.png`} />
  <script is:inline>
    (function(){try{var s=localStorage.getItem('portfolio-theme');var t=(s==='dark'||s==='light')?s:(window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');document.documentElement.classList.add('theme-'+t);}catch(_){}})();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=JetBrains+Mono:wght@300;400;500&family=Geist:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&family=Playfair+Display:wght@600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,300;1,8..60,400&display=swap" rel="stylesheet" />
  {useKatex && (
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.47/dist/katex.min.css"
          integrity="sha384-nH0MfJ44wi1dd7w6jinlyBgljjS8EJAh2JBoRad8a3VDw2K69vfaaqm4WnR+gXtA" crossorigin="anonymous" />
  )}
  {!useKatex && (
    <Fragment>
      <script is:inline>MathJax={tex:{inlineMath:[['$','$'],['\\(','\\)']],displayMath:[['$$','$$'],['\\[','\\]']]},svg:{scale:1.05,fontCache:'global'},options:{skipHtmlTags:['script','noscript','style','textarea','pre']}};</script>
      <script is:inline id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3.2.2/es5/tex-svg.js"
              integrity="sha384-KKWa9jJ1MZvssLeOoXG6FiOAZfAgmzsIIfw8BXwI9+kYm0lPCbC6yTQPBC00F1/L" crossorigin="anonymous"></script>
    </Fragment>
  )}
  <slot name="head" />
  <link rel="stylesheet" href={`${base}/css/style.css`} />
  <link rel="stylesheet" href={`${base}/css/notes/notes.css`} />
</head>
<body class="notes-layout-article">

<canvas class="cursor-trail-canvas" id="cursorTrailCanvas"></canvas>
<div class="cursor-pointer" id="cursorPointer"></div>

<div class="site-wrapper" id="main-layout">

  <!-- LEFT SIDEBAR (notes nav) -->
  <aside class="sidebar-left">
    <div class="sidebar-logo">
      <a href={`${base}/notes.html`} class="notes-back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        <span>All Notes</span>
      </a>
    </div>
    <nav class="sidebar-nav">
      <!-- Dynamic: content collection notes -->
      {collectionNotes.map(note => (
        <a
          href={`${base}/notes/${note.slug}.html`}
          class:list={['nav-item', { active: activeSlug === note.slug }]}
          data-abbr={note.slug.slice(0, 3).toUpperCase()}
        >
          <div>
            <div class="nav-label">{note.data.title}</div>
            {note.data.course && <div class="nav-sub">{note.data.course}</div>}
          </div>
        </a>
      ))}

      <!-- Static: legacy HTML notes -->
      <a href={`${base}/projects/RNN_LSTM_Calculator.html`}
         class:list={['nav-item', { active: activeNote === 'rnn' }]} data-abbr="RNN">
        <div><div class="nav-label">RNN &amp; LSTM Calc</div><div class="nav-sub">IF3270</div></div>
      </a>
      <a href={`${base}/notes/ml_lastterm_notes.html`}
         class:list={['nav-item', { active: activeNote === 'ml-lastterm' }]} data-abbr="ML2">
        <div><div class="nav-label">ML Last Term Notes</div><div class="nav-sub">IF3270</div></div>
      </a>
      <a href={`${base}/notes/ml_midterm_notes.html`}
         class:list={['nav-item', { active: activeNote === 'ml-midterm' }]} data-abbr="ML1">
        <div><div class="nav-label">ML Midterm Notes</div><div class="nav-sub">IF3270</div></div>
      </a>
      <a href={`${base}/notes/md-viewer.html`}
         class:list={['nav-item', { active: activeNote === 'md-viewer' }]} data-abbr="MD">
        <div><div class="nav-label">MD Viewer</div><div class="nav-sub">tool</div></div>
      </a>
    </nav>
    <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle theme" aria-pressed="false">
      <span class="theme-toggle-icon" aria-hidden="true">&#9728;</span>
      <span class="theme-toggle-label">Light</span>
    </button>
    <div class="sidebar-profile">
      <div class="avatar">S</div>
      <div class="profile-info">
        <div class="profile-name">Sayyaku</div>
        <div class="profile-handle">@SayyakuHajime</div>
      </div>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="main-content" style="max-width:none;flex:1;min-width:0;">
    {!hideHeader && (
      <div class="page-header">
        <span class="page-title" id="pg-title">{pageTitle}</span>
        <span class="header-meta" id="pg-meta">{pageMeta}</span>
      </div>
    )}
    <slot />
  </main>

  <!-- RIGHT RAIL -->
  <aside class="sidebar-right" style="width:240px;">
    <div style="position:sticky;top:0;padding-top:var(--sp-lg);">
      <div class="progress-bar-wrap">
        <div class="progress-bar-fill" id="readingProgress"></div>
      </div>
      <slot name="right-rail" />
      <button id="cursorToggleBtn" class="cursor-toggle-btn" type="button" aria-pressed="false">&#9679; pointer trail</button>
    </div>
  </aside>

</div>

<script is:inline src={`${base}/js/app.js`} defer></script>
<script is:inline src={`${base}/js/notes-common.js`}></script>
</body>
</html>
