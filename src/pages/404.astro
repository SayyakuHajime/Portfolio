---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="404 — Sayyaku"
  description="Page not found — Sayyaku's portfolio."
  ogTitle="404 — Page not found"
  ogDescription="The page you're looking for doesn't exist or has been moved."
>
  <style>
    .not-found-wrap {
      min-height: 60vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: var(--sp-xl);
      gap: var(--sp-md);
    }
    .not-found-code {
      font-family: var(--font-mono);
      font-size: 5rem;
      font-weight: 300;
      color: var(--accent-gold);
      line-height: 1;
      letter-spacing: -0.04em;
    }
    .not-found-title {
      font-family: var(--font-display);
      font-size: 1.75rem;
      font-weight: 400;
      color: var(--text-primary);
    }
    .not-found-sub {
      font-size: 0.9rem;
      color: var(--text-muted);
      max-width: 340px;
      line-height: 1.65;
    }
    .not-found-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 10px 22px;
      border-radius: var(--r-lg);
      background: var(--accent-gold);
      color: var(--bg-base);
      font-family: var(--font-ui);
      font-size: 0.875rem;
      font-weight: 500;
      text-decoration: none;
      transition: opacity 0.15s;
      margin-top: var(--sp-sm);
    }
    .not-found-link:hover { opacity: 0.88; }
  </style>

  <div class="not-found-wrap">
    <div class="not-found-code">404</div>
    <div class="not-found-title">Page not found</div>
    <p class="not-found-sub">The page you're looking for doesn't exist or has been moved.</p>
    <a href={`${base}/`} class="not-found-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/>
        <polyline points="9 21 9 12 15 12 15 21"/>
      </svg>
      Go home
    </a>
  </div>
</BaseLayout>
