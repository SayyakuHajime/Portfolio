---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;
const collectionNotes = (await getCollection('notes')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Notes - Sayyaku"
  description="Study notes and modular reference material for computer science courses - ML, mobile dev, algorithms, and more."
  ogTitle="Notes - Sayyaku"
  ogDescription="Study notes and modular reference material for CS courses."
  activePage="notes"
>
  <div class="page-header">
    <span class="page-title">Notes</span>
    <span class="header-meta">modular archive</span>
  </div>

  <section class="notes-intro animate-in">
    <h2>Study notes.</h2>
    <p>A collection of notes from various subjects.</p>
  </section>

  <!-- Notes from content collections (Markdown) -->
  {collectionNotes.map(note => (
    <article class="note-item animate-in">
      <div>
        <h2 class="note-title">
          <a href={`${base}/notes/${note.slug}.html`} class="note-title-link">{note.data.title}</a>
        </h2>
        {note.data.subject && <p class="note-desc">{note.data.subject}</p>}
        <div class="note-meta">
          {note.data.course && <span class="tag">{note.data.course}</span>}
          {note.data.topics && note.data.topics.map(t => <span class="tag">{t}</span>)}
        </div>
      </div>
    </article>
  ))}

  <!-- Legacy interactive tools -->
  <article class="note-item animate-in">
    <div>
      <h2 class="note-title"><a href={`${base}/projects/RNN_LSTM_Calculator.html`} class="note-title-link">RNN &amp; LSTM Calculator</a></h2>
      <p class="note-desc">Interactive construction kit for Vanilla RNN and LSTM cells. Tune dimensions, gates, topology, and regularization - see parameters, FLOPs, weight matrices, and unrolled timelines update live.</p>
      <div class="note-meta">
        <span class="tag">IF3270</span><span class="tag">RNN · LSTM</span><span class="tag">Interactive</span>
      </div>
    </div>
  </article>

  <div slot="right-rail">
    <div class="card animate-in">
      <div class="card-section"><p class="card-title">Why Notes?</p></div>
      <div class="divider"></div>
      <div class="contact-links">
        <div class="contact-link" style="cursor:default;">Notes help me organize and review information efficiently.</div>
        <div class="contact-link" style="cursor:default;">I use modular notes to break down complex topics into manageable sections.</div>
        <div class="contact-link" style="cursor:default;">Slides and textbooks can be overwhelming, so I create concise notes to focus on key concepts.</div>
      </div>
    </div>
    <div class="card animate-in">
      <div class="card-section"><p class="card-title">Disclaimer</p></div>
      <div class="divider"></div>
      <div class="contact-links">
        <div class="contact-link" style="cursor:default;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Notes are for personal reference and may contain errors. Use them as a starting point, not a definitive source.
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
