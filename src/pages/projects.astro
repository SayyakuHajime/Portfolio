---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;

const allProjects = (await getCollection('projects')).sort((a, b) =>
  (b.data.date ?? '').localeCompare(a.data.date ?? ''));

function fmtDate(s?: string) {
  if (!s) return '';
  const d = new Date(s + '-01T00:00:00');
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function resolveImage(img?: string) {
  if (!img) return null;
  if (img.startsWith('http')) return img;
  return `${base}${img}`;
}
---

<BaseLayout
  title="Projects — Sayyaku"
  description="Projects and experiments built by Sayyaku — ML tools, interactive calculators, and design work."
  ogTitle="Projects — Sayyaku"
  ogDescription="Projects and experiments — ML tools, interactive calculators, and design work."
  activePage="projects"
>
  <div class="page-header">
    <span class="page-title">Projects</span>
    <span class="header-meta">{allProjects.length > 0 ? `${allProjects.length} projects` : 'work in progress'}</span>
  </div>

  {allProjects.length > 0 && (
    <section class="projects-intro animate-in">
      <h2>Things I've built.</h2>
      <p>A collection of projects and experiments — algorithms, ML systems, and tools.</p>
    </section>
  )}

  {allProjects.map(project => {
    const imgSrc = resolveImage(project.data.image);
    const href = project.data.url ?? `${base}/projects/${project.slug}.html`;
    return (
      <article class="project-item animate-in">
        <a href={href} class="project-title-link" target={project.data.url ? '_blank' : '_self'} rel={project.data.url ? 'noopener noreferrer' : undefined}>
          <div class="project-header">
            <div class="project-body">
              <h2 class="project-name">{project.data.title}</h2>
              {project.data.description && <p class="project-desc">{project.data.description}</p>}
            </div>
            {imgSrc ? (
              <div class="project-thumb">
                <img src={imgSrc} alt={project.data.title} loading="lazy" />
              </div>
            ) : (
              <div class="project-thumb-placeholder">{'</>'}</div>
            )}
          </div>
          <div class="project-footer">
            <div class="project-stack">
              {project.data.tags?.map(t => <span class="tag">{t}</span>)}
              {project.data.date && <span class="tag">{fmtDate(project.data.date)}</span>}
            </div>
            {project.data.url && (
              <span class="project-link-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                GitHub
              </span>
            )}
          </div>
        </a>
      </article>
    );
  })}

  {allProjects.length === 0 && (
    <div class="projects-intro animate-in">
      <h2>Project garden is sleeping,<br>for now.</h2>
      <p>This page is being rebuilt. I will publish projects here once I finish curating the list and writing proper notes for each build.</p>
    </div>
  )}

  {allProjects.length === 0 && (
    <section class="wip-wrap animate-in">
      <article class="wip-card">
        <div class="wip-chip"><span class="wip-chip-dot"></span>WIP</div>
        <h2 class="wip-title">Projects section is under construction.</h2>
        <p class="wip-text">I am currently preparing cleaner writeups and project summaries. No public project cards are shown yet on this page.</p>
        <div class="wip-actions">
          <a href={`${base}/`} class="wip-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            Back to Home
          </a>
          <a href="https://github.com/SayyakuHajime" class="wip-link" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            GitHub profile
          </a>
        </div>
        <p class="wip-kitty">tiny workshop noises in progress</p>
      </article>
    </section>
  )}

  <div slot="right-rail">
    <div class="card animate-in">
      <div class="card-section"><p class="card-title">Project board</p></div>
      <div class="divider"></div>
      <div class="wip-side-note">
        <p><strong>Status:</strong> {allProjects.length} projects published.</p>
        <p>More coming soon.</p>
      </div>
    </div>
    <div class="card animate-in">
      <div class="card-section"><p class="card-title">Stack</p></div>
      <div class="divider"></div>
      <div class="skills-grid">
        <span class="skill-chip">Python</span>
        <span class="skill-chip">NumPy</span>
        <span class="skill-chip">JavaScript</span>
        <span class="skill-chip">Java</span>
        <span class="skill-chip">C++</span>
        <span class="skill-chip">Scala</span>
        <span class="skill-chip">Next.js</span>
        <span class="skill-chip">PyQt5</span>
      </div>
    </div>
  </div>
</BaseLayout>
